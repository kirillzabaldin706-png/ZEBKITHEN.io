rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /menu/{docId} {
      allow read: if true;
      allow write: if true;
    }
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
